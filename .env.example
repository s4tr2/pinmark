# --- Supabase ---
# Local dev: values printed by `supabase start`
# Hosted: from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App URLs ---
# Public URL of the web app (auth redirects, dashboard links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Where w.js is served from; may equal APP_URL
NEXT_PUBLIC_CDN_URL=http://localhost:3000

# --- Branding ---
# Working name; single source of truth for UI/emails/docs (PRD naming note)
NEXT_PUBLIC_BRAND_NAME=Pinmark

# --- Mail (M5) ---
MAILER=resend
RESEND_API_KEY=
SMTP_URL=
NOTIFY_FROM_EMAIL=notifications@example.com
