# --- Supabase (required) ---
# Local dev: values printed by `supabase start`
# Hosted or self-hosted: from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App URLs (required) ---
# Public URL of the web app (auth redirects, dashboard links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Where w.js is served from; may equal APP_URL
NEXT_PUBLIC_CDN_URL=http://localhost:3000

# --- Branding (required) ---
# Working name; single source of truth for UI/emails/docs (PRD naming note)
NEXT_PUBLIC_BRAND_NAME=Pinmark

# --- Deployment mode (required) ---
# true: serve only the product (dashboard, auth, API, widget delivery).
# No landing page, no playground, no hosted-service messaging. See
# DEPLOY.md for what this changes and does not change.
NEXT_PUBLIC_SELF_HOSTED=false

# --- Playground demo (optional) ---
# Public key of a Pinmark project used to power the live demo on /playground.
# Leave unset to show a "not connected" message instead. Self-hosted
# instances never load this regardless of whether it is set; see DEPLOY.md.
NEXT_PUBLIC_DEMO_KEY=

# --- Mail (optional) ---
# Leave MAILER unset to disable email notifications entirely.
MAILER=resend
RESEND_API_KEY=
SMTP_URL=
NOTIFY_FROM_EMAIL=notifications@example.com
